<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joymove.mapper.MomentLikeMapper">

    <select id="existsByUserAndMoment" resultType="int">
        SELECT COUNT(*) FROM moment_like
        WHERE user_id = #{userId} AND moment_id = #{momentId}
    </select>

</mapper>
