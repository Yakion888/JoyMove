<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joymove.mapper.FamilyPlanMapper">

    <resultMap id="BaseResultMap" type="com.joymove.entity.FamilyPlan">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="project_id" property="projectId"/>
        <result column="planned_date" property="plannedDate"/>
        <result column="status" property="status"/>
        <result column="actual_duration" property="actualDuration"/>
        <result column="child_feedback" property="childFeedback"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByDateRange" resultMap="BaseResultMap">
        SELECT * FROM family_plan
        WHERE user_id = #{userId} AND is_deleted = 0
        AND planned_date BETWEEN #{startDate} AND #{endDate}
        ORDER BY planned_date ASC
    </select>

</mapper>
